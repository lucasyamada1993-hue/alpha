{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext", "dom"],
    "target": "esnext",
    "checkJs": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": []
  },
  "include": [
    "src/vite-env.d.ts",
    "src/components/**/*.js",
    "src/components/ui/dialog.tsx",
    "src/components/ui/input.tsx",
    "src/components/ui/label.jsx",
    "src/components/ui/select.tsx",
    "src/pages/**/*.jsx",
    "src/Layout.jsx"
  ],
  "exclude": ["node_modules", "dist", "src/vite-plugins", "src/api", "src/lib"]
} 