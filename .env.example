# Copie para .env e ajuste. O arquivo .env não deve ser commitado.

# --- Local (npm run dev) — obrigatório para evitar CORS com o Google ---
# NÃO coloque a URL do script.google.com em VITE_SHEETS_API_URL (o navegador bloqueia).
VITE_SHEETS_API_URL=/api/sheets
# Use UMA das duas linhas abaixo (mesma URL /exec do Web App):
APPS_SCRIPT_WEB_APP_URL=https://script.google.com/macros/s/SEU_DEPLOYMENT_ID/exec
# VITE_APPS_SCRIPT_WEB_APP_URL=https://script.google.com/macros/s/SEU_DEPLOYMENT_ID/exec

# --- Produção (Vercel) ---
# VITE_SHEETS_API_URL=/api/sheets
# No painel da Vercel (Environment Variables), servidor:
# APPS_SCRIPT_WEB_APP_URL=https://script.google.com/macros/s/SEU_DEPLOYMENT_ID/exec

# O mesmo endpoint alimenta pesquisa, perfis, dashboard, etc.
#
# Testes (requer APPS_SCRIPT_WEB_APP_URL preenchida):
#   npm run test:sheets      — grava 1 linha de teste em SurveyResponse
#   npm run test:sheets:all  — list em todas as abas (só leitura)
